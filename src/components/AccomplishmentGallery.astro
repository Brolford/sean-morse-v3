---
/**
 * AccomplishmentGallery.astro
 * Cinematic masonry grid of Sean's best project images.
 * Placed between the hero and featured scroll — immediate visual proof.
 *
 * 8 curated images in a staggered 3-column masonry layout.
 * Each image links to its case study page.
 * Scroll-triggered reveal with staggered entrance.
 */
---

<section class="gallery section-light" data-nav-theme="light" aria-label="Selected work">
  <!-- Section overline -->
  <p class="gallery__overline text-label animate-reveal">Selected Work</p>

  <!-- Masonry grid — 3 columns, staggered heights -->
  <div class="gallery__grid">

    <!-- Column 1 — starts flush -->
    <div class="gallery__column gallery__column--1">
      <a href="/work/alecs-ice-cream" class="gallery__item animate-reveal animate-stagger" data-delay="1" aria-label="Alec's Ice Cream brand identity project">
        <img
          src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/d04ab052-bd59-4dc7-80b8-4aa3d25c4597/Alecs_CaseStudy_Layout_V3-14.jpg"
          alt="Alec's Ice Cream — colorful packaging lineup against a vibrant purple backdrop"
          width="640"
          height="800"
          loading="eager"
          fetchpriority="high"
          class="gallery__img"
        />
        <div class="gallery__overlay">
          <span class="gallery__category">Brand Identity</span>
          <span class="gallery__name">Alec's Ice Cream</span>
        </div>
      </a>
      <a href="/work/elenita-mezcal" class="gallery__item gallery__item--short animate-reveal animate-stagger" data-delay="4" aria-label="Elenita Mezcal branding project">
        <img
          src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/e72a21ce-5d4f-4e97-8d36-1b39f0af3f99/Elenita_CaseStudy_2023_WildPosting_V5.jpg"
          alt="Elenita Mezcal — wild posting street campaign with bold typographic treatment"
          width="640"
          height="480"
          loading="lazy"
          class="gallery__img"
        />
        <div class="gallery__overlay">
          <span class="gallery__category">Brand & Packaging</span>
          <span class="gallery__name">Elenita Mezcal</span>
        </div>
      </a>
    </div>

    <!-- Column 2 — offset down for stagger effect -->
    <div class="gallery__column gallery__column--2">
      <a href="/work/v8" class="gallery__item gallery__item--short animate-reveal animate-stagger" data-delay="2" aria-label="V8 packaging redesign project">
        <img
          src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/b7e25c3d-e8c6-411e-a312-6a97ab932153/V8_CaseStudy_2023_Core_OG_Scene_1_V2.jpg"
          alt="V8 — original vegetable juice bottles in a styled product shot"
          width="640"
          height="480"
          loading="lazy"
          class="gallery__img"
        />
        <div class="gallery__overlay">
          <span class="gallery__category">Packaging</span>
          <span class="gallery__name">V8 + Campbell's</span>
        </div>
      </a>
      <a href="/work/over-easy" class="gallery__item animate-reveal animate-stagger" data-delay="5" aria-label="Over Easy breakfast bar branding project">
        <img
          src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/d5a20cf1-b90b-4b11-908b-389d5c54842f/OverEasy_CaseStudy_2023_PB_Bar_Photography_Tile_V2.jpg"
          alt="Over Easy — peanut butter breakfast bar with warm product photography"
          width="640"
          height="800"
          loading="lazy"
          class="gallery__img"
        />
        <div class="gallery__overlay">
          <span class="gallery__category">Brand & Packaging</span>
          <span class="gallery__name">Over Easy</span>
        </div>
      </a>
    </div>

    <!-- Column 3 — slight offset -->
    <div class="gallery__column gallery__column--3">
      <a href="/work/leisure-project" class="gallery__item animate-reveal animate-stagger" data-delay="3" aria-label="Leisure Project beverage branding">
        <img
          src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/9ff9645b-460a-467f-a9b3-f029b99ef2bb/Leisure_CaseStudy_BL_Can.jpg"
          alt="Leisure Project — botanical lemonade can against a dreamy blue background"
          width="640"
          height="800"
          loading="lazy"
          class="gallery__img"
        />
        <div class="gallery__overlay">
          <span class="gallery__category">Packaging</span>
          <span class="gallery__name">Leisure Project</span>
        </div>
      </a>
      <a href="/work/mimio" class="gallery__item gallery__item--short animate-reveal animate-stagger" data-delay="6" aria-label="Mimio health supplement branding">
        <img
          src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/1af08af1-244d-4771-97bf-c05568cb32c8/Mimio_CaseStudy_Layout_V4-03.jpg"
          alt="Mimio — longevity supplement packaging with clean clinical aesthetic"
          width="640"
          height="480"
          loading="lazy"
          class="gallery__img"
        />
        <div class="gallery__overlay">
          <span class="gallery__category">Brand & Packaging</span>
          <span class="gallery__name">Mimio</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  /* ====================================================================
     Accomplishment Gallery — Cinematic masonry grid
     ==================================================================== */

  .gallery {
    padding: var(--space-7) var(--space-5) var(--space-8);
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Section overline ── */
  .gallery__overline {
    color: #7D5F40; /* Darkened from --accent-bronze for 4.5:1 contrast on canvas */
    text-align: center;
    margin-bottom: var(--space-6);
  }

  /* ── 3-column masonry grid ── */
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    align-items: start;
  }

  /* ── Columns with stagger offsets ── */
  .gallery__column {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .gallery__column--2 {
    margin-top: var(--space-7);
  }

  .gallery__column--3 {
    margin-top: var(--space-5);
  }

  /* ── Individual gallery items ── */
  .gallery__item {
    position: relative;
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .gallery__item--short {
    aspect-ratio: 4 / 3;
  }

  .gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Hover overlay with project name ── */
  .gallery__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-4);
    background: linear-gradient(
      to top,
      rgba(12, 12, 11, 0.65) 0%,
      rgba(12, 12, 11, 0.15) 40%,
      transparent 70%
    );
    opacity: 0;
    pointer-events: none;
  }

  .gallery__category {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-gold);
    margin-bottom: var(--space-1);
  }

  .gallery__name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    color: var(--text-cream);
    line-height: 1.2;
  }

  /* ── Hover interactions (hover-capable only) ── */
  @media (hover: hover) {
    .gallery__item {
      transition: transform 400ms var(--ease-spring);
    }

    .gallery__overlay {
      transition: opacity 300ms var(--ease-smooth);
    }

    .gallery__item:hover {
      transform: translateY(-6px);
    }

    .gallery__item:hover .gallery__overlay {
      opacity: 1;
    }
  }

  /* ── Focus styles for keyboard navigation ── */
  .gallery__item:focus-visible {
    outline: 2px solid var(--accent-bronze);
    outline-offset: 3px;
  }

  .gallery__item:focus-visible .gallery__overlay {
    opacity: 1;
  }

  /* ── Tablet: 2 columns ── */
  @media (max-width: 900px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Third column wraps under — hide its offset */
    .gallery__column--3 {
      margin-top: 0;
    }
  }

  /* ── Mobile: single column, no stagger offsets ── */
  @media (max-width: 640px) {
    .gallery {
      padding: var(--space-6) var(--space-3) var(--space-7);
    }

    .gallery__grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .gallery__column--2 {
      margin-top: 0;
    }

    /* Shorter aspect ratios on mobile for less scroll */
    .gallery__item {
      aspect-ratio: 3 / 2;
    }

    .gallery__item--short {
      aspect-ratio: 16 / 9;
    }

    /* Always show overlay on mobile (no hover) */
    .gallery__overlay {
      opacity: 1;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .gallery__item,
    .gallery__item:hover {
      transform: none !important;
      transition: none;
    }
  }
</style>
