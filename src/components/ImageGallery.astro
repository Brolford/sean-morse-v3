---
/**
 * ImageGallery.astro — 2-column masonry-style image grid for case studies.
 *
 * Props:
 *   images — Array of image URL strings.
 *   alt    — Base string for alt text (project title). Each image gets
 *            "alt — project image N" for contextual accessibility.
 *
 * Layout:
 *   CSS grid, 2 columns, gap 12px (--radius-md).
 *   First image + every 5th spans full width for visual rhythm.
 *   Single column on mobile (<640px).
 *
 * Performance:
 *   - Squarespace CDN ?format=Nw param normalized on every image so the
 *     CDN delivers a sensibly-sized file (not the original 5MB+ source).
 *   - srcset across 500/750/1100/1500/2500w lets the browser pick by DPR.
 *   - First image eager + high fetchpriority (above the fold).
 *   - Remaining images lazy with async decoding.
 */
const { images = [], alt = 'Project' } = Astro.props;
const hasImages = images.length > 0;

/* Append/replace ?format=Nw on a Squarespace CDN URL. Falls back gracefully
   for non-Squarespace URLs by appending the param if URL parses cleanly. */
function withSize(src: string, width: number): string {
  try {
    const url = new URL(src);
    url.searchParams.set('format', `${width}w`);
    return url.toString();
  } catch {
    return src;
  }
}

/* Generate a srcset string covering the common viewport widths × DPRs.
   Browser picks the best candidate based on the `sizes` attribute. */
function buildSrcset(src: string): string {
  return [500, 750, 1100, 1500, 2500]
    .map(w => `${withSize(src, w)} ${w}w`)
    .join(', ');
}

/* Index-based: first image, plus every 5th after, span the full width.
   Matches the CSS grid rule below — kept here to drive the sizes attr. */
function isFullWidth(i: number): boolean {
  return i === 0 || i % 5 === 0;
}
---

{hasImages && (
  <div class="image-gallery">
    {images.map((src, i) => (
      <div
        class="gallery__item animate-reveal animate-stagger"
        data-delay={String(Math.min(i + 1, 4))}
      >
        <img
          src={withSize(src, 1500)}
          srcset={buildSrcset(src)}
          sizes={isFullWidth(i)
            ? "(max-width: 1100px) 100vw, 1100px"
            : "(max-width: 640px) 100vw, (max-width: 1100px) 50vw, 550px"}
          alt={`${alt} — project image ${i + 1}`}
          class="gallery__img"
          loading={i === 0 ? "eager" : "lazy"}
          fetchpriority={i === 0 ? "high" : "auto"}
          decoding="async"
          width="800"
          height="600"
        />
      </div>
    ))}
  </div>
)}

<style>
  /* ── Grid container — 2 columns with 12px gap ── */
  .image-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--radius-md);
  }

  /* ── First image spans full width as hero ── */
  .gallery__item:first-child {
    grid-column: 1 / -1;
  }

  /* ── Every 5th image (after first) also spans full width for rhythm ── */
  .gallery__item:nth-child(5n+1):not(:first-child) {
    grid-column: 1 / -1;
  }

  /* ── Image styling ── */
  .gallery__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-md);
    object-fit: cover;
  }

  /* ── Mobile: single column ── */
  @media (max-width: 640px) {
    .image-gallery {
      grid-template-columns: 1fr;
    }

    .gallery__item:first-child,
    .gallery__item:nth-child(5n+1) {
      grid-column: 1;
    }
  }
</style>
