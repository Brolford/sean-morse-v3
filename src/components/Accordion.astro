---
/**
 * Accordion.astro — Expandable section list for case study pages.
 *
 * Props:
 *   items — Array of { title: string, content: string } objects.
 *           Each item renders as a collapsible section with a +/x toggle.
 *
 * Behavior:
 *   - max-height 0 -> scrollHeight transition (300ms spring)
 *   - +/x icon toggles on open/close
 *   - Re-binds on astro:page-load for View Transitions
 */
const { items = [] } = Astro.props;
---

{items.length > 0 && (
  <div class="accordion">
    {items.map((item, i) => (
      <div class="accordion__item" data-accordion-item>
        <button
          type="button"
          class="accordion__trigger"
          aria-expanded="false"
          aria-controls={`accordion-content-${i}`}
        >
          <span class="accordion__title">{item.title}</span>
          <span class="accordion__icon" aria-hidden="true">+</span>
        </button>
        <div
          class="accordion__content"
          id={`accordion-content-${i}`}
          role="region"
        >
          <p class="accordion__text">{item.content}</p>
        </div>
      </div>
    ))}
  </div>
)}

<style>
  /* ── Accordion container ── */
  .accordion {
    width: 100%;
  }

  /* ── Individual item — separated by bottom border ── */
  .accordion__item {
    border-bottom: 1px solid var(--surface-stone);
  }

  /* ── Trigger button — full-width row with title + icon ── */
  .accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-4) 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    /* 44px minimum touch target */
    min-height: 44px;
    gap: var(--space-3);
  }

  .accordion__trigger:focus-visible {
    outline: 2px solid var(--accent-bronze);
    outline-offset: 2px;
  }

  /* ── Title — Instrument Serif display style ── */
  .accordion__title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    color: var(--text-ink);
    line-height: 1.3;
  }

  /* ── Plus/times icon ── */
  .accordion__icon {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 300;
    color: var(--text-muted);
    flex-shrink: 0;
    width: 24px;
    text-align: center;
    transition: transform 300ms var(--ease-spring);
    user-select: none;
  }

  /* ── Collapsible content area ── */
  .accordion__content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 300ms var(--ease-spring),
      opacity 200ms var(--ease-smooth);
  }

  /* ── Content text — Space Grotesk body ── */
  .accordion__text {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--text-body-color);
    padding-bottom: var(--space-4);
  }

  /* ── Hover state for trigger ── */
  @media (hover: hover) {
    .accordion__trigger:hover .accordion__title {
      color: var(--accent-bronze);
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .accordion__content {
      transition: opacity 200ms ease;
    }

    .accordion__icon {
      transition: none;
    }
  }
</style>

<script is:inline>
/**
 * Accordion toggle logic.
 * Binds click handlers to all accordion triggers.
 * Re-initializes on astro:page-load for View Transitions.
 */
function initAccordions() {
  var triggers = document.querySelectorAll('[data-accordion-item] .accordion__trigger');
  triggers.forEach(function (btn) {
    /* Avoid double-binding if already initialized */
    if (btn.dataset.accordionBound) return;
    btn.dataset.accordionBound = 'true';

    btn.addEventListener('click', function () {
      var item = btn.closest('[data-accordion-item]');
      var content = item.querySelector('.accordion__content');
      var icon = item.querySelector('.accordion__icon');
      var isOpen = btn.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        /* Close */
        content.style.maxHeight = '0';
        content.style.opacity = '0';
        icon.textContent = '+';
        btn.setAttribute('aria-expanded', 'false');
      } else {
        /* Open */
        content.style.maxHeight = content.scrollHeight + 'px';
        content.style.opacity = '1';
        icon.textContent = '\u00d7';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
}

/* Initialize on first load */
initAccordions();

/* Re-initialize after View Transitions */
document.addEventListener('astro:page-load', initAccordions);
</script>
