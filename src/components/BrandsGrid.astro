---
/**
 * BrandsGrid — 5-column brand names grid replacing the marquee ticker.
 * Each cell shows a brand name in uppercase, gold on hover.
 * Staggered scroll-reveal animation on each cell.
 */
const brands = [
  'Liquid I.V.',
  'V8',
  "Campbell's",
  "Alec's",
  'SmartyPants',
  'Elenita',
  'Over Easy',
  'Leisure',
  'Mimio',
  'Picture Day',
];
---

<section class="section-dark brands-section" data-nav-theme="dark">
  {/* Section label */}
  <span class="text-label brands-section__label">Brands Worked With</span>

  {/* Grid of brand names */}
  <div class="brands-grid" role="list">
    {brands.map((brand, i) => (
      <div
        class="brands-grid__cell animate-reveal animate-stagger"
        data-delay={Math.min(i + 1, 8).toString()}
        role="listitem"
      >
        {brand}
      </div>
    ))}
  </div>
</section>

<style>
  /* ── Section wrapper ── */
  .brands-section {
    padding: var(--space-5) var(--space-5) var(--space-section);
  }

  /* ── Label ── */
  .brands-section__label {
    display: block;
    color: var(--text-fog); /* #B5AFA5 — passes 4.5:1 on charcoal */
    margin-bottom: var(--space-3);
  }

  /* ── 5-column grid with 1px gap as visual dividers ── */
  .brands-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, 0.04);
  }

  /* ── Individual brand cell ── */
  .brands-grid__cell {
    background: var(--surface-charcoal);
    padding: var(--space-4) var(--space-3);
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: #444444;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: color 200ms var(--ease-smooth);
    line-height: 1.4;
  }

  /* ── Hover: gold accent ── */
  @media (hover: hover) {
    .brands-grid__cell:hover {
      color: var(--accent-gold);
    }
  }

  /* ── Mobile: 3 columns ── */
  @media (max-width: 640px) {
    .brands-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Reduced motion: no stagger ── */
  @media (prefers-reduced-motion: reduce) {
    .brands-grid__cell {
      transition: none;
    }
  }
</style>
