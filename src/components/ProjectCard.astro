---
/**
 * ProjectCard — Individual project card for the bento grid.
 * Displays project gradient or hero image, category label, and title.
 * Uses card-breathe animation and hover-lift from global.css.
 */
interface Props {
  project: {
    slug: string;
    title: string;
    category: string;
    gradientClass?: string;
    image?: string;
    year: string;
  };
}

const { project } = Astro.props;
---

<a
  href={`/work/${project.slug}`}
  class="project-card card-breathe hover-lift animate-reveal"
  data-category={project.category}
  aria-label={`View ${project.title} — ${project.category}, ${project.year}`}
>
  {/* Background: hero image or gradient fallback */}
  {project.image ? (
    <img
      src={project.image}
      alt=""
      aria-hidden="true"
      class="project-card__bg"
      loading="lazy"
      width="400"
      height="320"
    />
  ) : (
    <div class={`project-card__bg-gradient ${project.gradientClass || ''}`} />
  )}

  {/* Bottom overlay for text legibility */}
  <div class="project-card__overlay" aria-hidden="true" />

  {/* Content */}
  <div class="project-card__content">
    <span class="project-card__category">{project.category}</span>
    <h3 class="project-card__title">{project.title}</h3>
  </div>
</a>

<style>
  /* ── Card wrapper ── */
  .project-card {
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: var(--space-3);
    text-decoration: none;
    color: inherit;
  }

  /* ── Background image (absolute fill) ── */
  .project-card__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* ── Gradient fallback (absolute fill) ── */
  .project-card__bg-gradient {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* ── Bottom gradient overlay for text legibility ── */
  .project-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      transparent 50%
    );
  }

  /* ── Text content ── */
  .project-card__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .project-card__category {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.4;
  }

  .project-card__title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
    color: #ffffff;
    line-height: 1.1;
    margin: 0;
  }
</style>
