---
/**
 * FeaturedScroll — Continuous horizontal scroll of featured project cards.
 * Dark section with seamless looping marquee animation.
 * Cards duplicate to create infinite loop illusion.
 * Pauses on hover, disabled on reduced-motion (static layout).
 */
import { projects } from '../data/projects.js';
const featured = projects.filter(p => p.featured && !p.comingSoon);
---

<section class="section-dark featured-scroll" data-nav-theme="dark">
  <h2 class="text-label featured-scroll__label animate-reveal">Featured Work</h2>

  <!-- Marquee track — contains two copies of the cards for seamless loop -->
  <div class="featured-scroll__marquee">
    <div class="featured-scroll__track">
      {/* First set */}
      {featured.map((project) => (
        <a
          href={`/work/${project.slug}`}
          class="featured-card hover-lift"
          aria-label={`View ${project.title} case study`}
        >
          {project.image ? (
            <img
              src={project.image}
              alt=""
              aria-hidden="true"
              class="featured-card__bg"
              loading="lazy"
              width="420"
              height="520"
            />
          ) : (
            <div class={`featured-card__bg-gradient ${project.gradientClass || ''}`} />
          )}
          <div class="featured-card__overlay" aria-hidden="true" />
          <div class="featured-card__content">
            <span class="featured-card__category">{project.category}</span>
            <h3 class="featured-card__title">{project.title}</h3>
            <span class="featured-card__year">{project.year}</span>
          </div>
        </a>
      ))}
      {/* Duplicate set for seamless loop */}
      {featured.map((project) => (
        <a
          href={`/work/${project.slug}`}
          class="featured-card hover-lift"
          aria-hidden="true"
          tabindex="-1"
        >
          {project.image ? (
            <img
              src={project.image}
              alt=""
              aria-hidden="true"
              class="featured-card__bg"
              loading="lazy"
              width="420"
              height="520"
            />
          ) : (
            <div class={`featured-card__bg-gradient ${project.gradientClass || ''}`} />
          )}
          <div class="featured-card__overlay" aria-hidden="true" />
          <div class="featured-card__content">
            <span class="featured-card__category">{project.category}</span>
            <h3 class="featured-card__title">{project.title}</h3>
            <span class="featured-card__year">{project.year}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section wrapper ── */
  .featured-scroll {
    padding: var(--space-section) 0 var(--space-7);
    overflow: hidden;
  }

  /* ── Label ── */
  .featured-scroll__label {
    display: block;
    color: var(--accent-gold);
    padding: 0 var(--space-5);
    margin-bottom: var(--space-4);
  }

  /* ── Marquee container ── */
  .featured-scroll__marquee {
    overflow: hidden;
    width: 100%;
    /* Extra vertical padding so hover-lift doesn't clip at top */
    padding: 16px 0;
  }

  /* ── Track — holds 2x the cards, animates left ── */
  .featured-scroll__track {
    display: flex;
    gap: 20px;
    width: max-content;
    animation: marquee-scroll 22s linear infinite;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Move exactly half the track (one full set of cards) */
      transform: translateX(-50%);
    }
  }

  /* ── Pause on hover ── */
  @media (hover: hover) {
    .featured-scroll__marquee:hover .featured-scroll__track {
      animation-play-state: paused;
    }
  }

  /* ── Individual card ── */
  .featured-card {
    flex: 0 0 420px;
    height: 520px;
    border-radius: var(--radius-lg);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    text-decoration: none;
    color: inherit;
  }

  /* Background image (absolute fill) */
  .featured-card__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* Gradient fallback (absolute fill) */
  .featured-card__bg-gradient {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Bottom gradient overlay for text legibility */
  .featured-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      transparent 70%
    );
  }

  /* Card text content */
  .featured-card__content {
    position: relative;
    z-index: 2;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .featured-card__category {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.4;
  }

  .featured-card__title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    color: #ffffff;
    line-height: 1.15;
    margin: 0;
  }

  .featured-card__year {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.4;
  }

  /* ── Mobile: smaller cards, slower scroll ── */
  @media (max-width: 640px) {
    .featured-card {
      flex: 0 0 300px;
      height: 400px;
    }

    .featured-scroll__track {
      animation-duration: 18s;
    }
  }

  /* ── Reduced motion: no scroll, static row ── */
  @media (prefers-reduced-motion: reduce) {
    .featured-scroll__track {
      animation: none;
    }

    .featured-scroll__marquee {
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .featured-scroll__marquee::-webkit-scrollbar {
      display: none;
    }
  }
</style>
