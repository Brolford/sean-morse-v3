---
/**
 * TrophyCase.astro — Unified credibility block.
 * Stats bar (6 project-attributed results) + brands ribbon.
 * Single dark section between Hero and Featured Scroll.
 */
const brands = [
  'Liquid I.V.', 'V8', "Campbell's", "Alec's", 'SmartyPants',
  'Elenita', 'Over Easy', 'Leisure', 'Mimio', 'Picture Day',
];
---

<section class="trophy section-dark" data-nav-theme="dark" aria-label="Career recognition and impact">
  <div class="trophy__glow" aria-hidden="true"></div>

  <div class="trophy__inner">
    <!-- Section overline -->
    <h2 class="text-label trophy__overline animate-reveal">Recognition & Impact</h2>

    <!-- Stats bar -->
    <div class="trophy__bar">
      <div class="trophy__cell animate-reveal animate-stagger" data-delay="1">
        <div class="trophy__stat">#1</div>
        <span class="trophy__label">Dieline Award</span>
        <span class="trophy__attribution">Alec's Ice Cream</span>
      </div>

      <div class="trophy__divider" aria-hidden="true"></div>

      <div class="trophy__cell animate-reveal animate-stagger" data-delay="2">
        <div class="trophy__stat" data-count-to="320" data-count-prefix="$" data-count-suffix="M+">$320M+</div>
        <span class="trophy__label">Revenue Influenced</span>
        <span class="trophy__attribution">Liquid I.V.</span>
      </div>

      <div class="trophy__divider" aria-hidden="true"></div>

      <div class="trophy__cell animate-reveal animate-stagger" data-delay="3">
        <div class="trophy__stat" data-count-to="7" data-count-suffix="x">7x</div>
        <span class="trophy__label">Distribution Growth</span>
        <span class="trophy__attribution">Alec's Ice Cream</span>
      </div>

      <div class="trophy__divider" aria-hidden="true"></div>

      <div class="trophy__cell animate-reveal animate-stagger" data-delay="4">
        <div class="trophy__stat">Acquired</div>
        <span class="trophy__label">By Unilever</span>
        <span class="trophy__attribution">Liquid I.V.</span>
      </div>

      <div class="trophy__divider" aria-hidden="true"></div>

      <div class="trophy__cell animate-reveal animate-stagger" data-delay="5">
        <div class="trophy__stat">NEXTY</div>
        <span class="trophy__label">Finalist &times;2</span>
        <span class="trophy__attribution">Alec's Ice Cream</span>
      </div>

      <div class="trophy__divider" aria-hidden="true"></div>

      <div class="trophy__cell animate-reveal animate-stagger" data-delay="6">
        <div class="trophy__stat">Whole Foods</div>
        <span class="trophy__label">National Placement</span>
        <span class="trophy__attribution">Alec's Ice Cream</span>
      </div>
    </div>

    <!-- Brands ribbon -->
    <div class="trophy__brands animate-reveal">
      <span class="trophy__brands-label">Brand Portfolio</span>
      <div class="trophy__brands-list">
        {brands.map((brand, i) => (
          <Fragment>
            {i > 0 && <span class="trophy__brands-dot" aria-hidden="true">&middot;</span>}
            <span class="trophy__brands-name">{brand}</span>
          </Fragment>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ====================================================================
     Trophy Case — Unified Credibility Block
     ==================================================================== */

  .trophy {
    padding: var(--space-8) var(--space-5);
    position: relative;
    overflow: hidden;
  }

  .trophy__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 50% 35%,
      rgba(212, 165, 116, 0.05) 0%,
      transparent 60%
    );
    z-index: 0;
  }

  .trophy__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Overline ── */
  .trophy__overline {
    color: var(--accent-gold);
    text-align: center;
    margin-bottom: var(--space-6);
  }

  /* ── Stats bar ── */
  .trophy__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: var(--space-5) 0;
  }

  .trophy__divider {
    width: 1px;
    align-self: stretch;
    background: rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  /* ── Stat cell ── */
  .trophy__cell {
    flex: 1;
    text-align: center;
    padding: var(--space-3) var(--space-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    min-width: 0;
  }

  .trophy__stat {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.2vw, 44px);
    font-weight: 400;
    color: var(--accent-gold);
    line-height: 1;
    text-shadow: 0 0 60px rgba(212, 165, 116, 0.08);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .trophy__label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #7D5F40;
    line-height: 1.4;
    margin-top: 6px;
    white-space: nowrap;
  }

  .trophy__attribution {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    color: var(--text-fog);
    line-height: 1.4;
    white-space: nowrap;
  }

  /* ── Brands ribbon ── */
  .trophy__brands {
    margin-top: var(--space-6);
    text-align: center;
  }

  .trophy__brands-label {
    display: block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-fog);
    margin-bottom: var(--space-3);
  }

  .trophy__brands-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px 20px;
  }

  .trophy__brands-name {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #8A857D;
    line-height: 1.4;
    transition: color 200ms var(--ease-smooth);
  }

  .trophy__brands-dot {
    color: rgba(255, 255, 255, 0.12);
    font-size: 14px;
    line-height: 1;
  }

  @media (hover: hover) {
    .trophy__brands-name:hover {
      color: var(--accent-gold);
    }
  }

  /* ── Tablet: 3x2 stats ── */
  @media (max-width: 900px) {
    .trophy__bar {
      flex-wrap: wrap;
    }

    .trophy__cell {
      flex: 0 0 33.333%;
      padding: var(--space-4) var(--space-2);
    }

    .trophy__divider {
      display: none;
    }

    /* Bottom border on first row of 3 */
    .trophy__cell:nth-child(-n+5) {
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
  }

  /* ── Mobile: 2-col stats, brands stack ── */
  @media (max-width: 480px) {
    .trophy {
      padding: var(--space-7) var(--space-3);
    }

    .trophy__bar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding: 0;
    }

    .trophy__divider {
      display: none;
    }

    .trophy__cell {
      padding: var(--space-4) var(--space-3);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .trophy__cell:nth-child(odd) {
      border-right: 1px solid rgba(255, 255, 255, 0.06);
    }

    .trophy__cell:nth-last-of-type(-n+2) {
      border-bottom: none;
    }

    .trophy__brands-list {
      gap: 4px 16px;
    }

    .trophy__brands-name {
      font-size: 10px;
    }
  }
</style>
