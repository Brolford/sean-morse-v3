---
/**
 * TrophyCase.astro — Editorial Ledger credibility section.
 * 2x3 grid of Sean's most impressive project outcomes.
 * Pure social proof — no images, stats are the visual.
 * Sits between Hero and Featured Scroll on homepage.
 */
---

<section class="trophy section-dark" data-nav-theme="dark" aria-label="Career recognition and impact">
  <!-- Radial bronze glow behind grid -->
  <div class="trophy__glow" aria-hidden="true"></div>

  <div class="trophy__inner">
    <!-- Section overline -->
    <h2 class="text-label trophy__overline animate-reveal">Recognition</h2>

    <!-- 2x3 ledger grid -->
    <div class="trophy__grid">

      <!-- Row 1 -->
      <div class="trophy__cell animate-reveal animate-stagger" data-delay="1">
        <div class="trophy__stat">#1</div>
        <span class="trophy__label">Dieline Award — Dairy</span>
        <span class="trophy__attribution">Alec's Ice Cream</span>
      </div>
      <div class="trophy__cell animate-reveal animate-stagger" data-delay="2">
        <div class="trophy__stat" data-count-to="320" data-count-prefix="$" data-count-suffix="M+">$320M+</div>
        <span class="trophy__label">Revenue Influenced</span>
        <span class="trophy__attribution">Liquid I.V.</span>
      </div>

      <!-- Row 2 -->
      <div class="trophy__cell animate-reveal animate-stagger" data-delay="3">
        <div class="trophy__stat" data-count-to="7" data-count-suffix="x">7x</div>
        <span class="trophy__label">Distribution Growth</span>
        <span class="trophy__attribution">Alec's Ice Cream</span>
      </div>
      <div class="trophy__cell animate-reveal animate-stagger" data-delay="4">
        <div class="trophy__stat">Acquired</div>
        <span class="trophy__label">By Unilever</span>
        <span class="trophy__attribution">Liquid I.V.</span>
      </div>

      <!-- Row 3 -->
      <div class="trophy__cell animate-reveal animate-stagger" data-delay="5">
        <div class="trophy__stat">NEXTY</div>
        <span class="trophy__label">Finalist &times;2</span>
        <span class="trophy__attribution">Alec's Ice Cream</span>
      </div>
      <div class="trophy__cell animate-reveal animate-stagger" data-delay="6">
        <div class="trophy__stat">Whole Foods</div>
        <span class="trophy__label">National Placement</span>
        <span class="trophy__attribution">Alec's Ice Cream</span>
      </div>

    </div>
  </div>
</section>

<style>
  /* ====================================================================
     Trophy Case — Editorial Ledger
     ==================================================================== */

  .trophy {
    padding: var(--space-section) var(--space-5);
    position: relative;
    overflow: hidden;
  }

  /* ── Radial bronze glow ── */
  .trophy__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 50% 40%,
      rgba(212, 165, 116, 0.05) 0%,
      transparent 60%
    );
    z-index: 0;
  }

  .trophy__inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  /* ── Overline ── */
  .trophy__overline {
    color: var(--accent-gold);
    text-align: center;
    margin-bottom: var(--space-6);
  }

  /* ── 2x3 grid with hairline dividers ── */
  .trophy__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ── Individual cell ── */
  .trophy__cell {
    text-align: center;
    padding: var(--space-5) var(--space-4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  /* Vertical divider — every odd cell gets a right border */
  .trophy__cell:nth-child(odd) {
    border-right: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* Remove bottom border from last row */
  .trophy__cell:nth-last-child(-n+2) {
    border-bottom: none;
  }

  /* ── Stat number ── */
  .trophy__stat {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 400;
    color: var(--accent-gold);
    line-height: 1;
    text-shadow: 0 0 60px rgba(212, 165, 116, 0.08);
  }

  /* ── Label ── */
  .trophy__label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #7D5F40; /* Darkened bronze — passes 4.5:1 on charcoal */
    line-height: 1.4;
    margin-top: var(--space-1);
  }

  /* ── Attribution (project name) ── */
  .trophy__attribution {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    color: var(--text-fog);
    line-height: 1.4;
  }

  /* ── Mobile: single column ── */
  @media (max-width: 480px) {
    .trophy__grid {
      grid-template-columns: 1fr;
    }

    /* Remove vertical dividers */
    .trophy__cell:nth-child(odd) {
      border-right: none;
    }

    /* All cells get bottom border except the last */
    .trophy__cell {
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .trophy__cell:last-child {
      border-bottom: none;
    }
  }
</style>
