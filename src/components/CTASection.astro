---
/**
 * CTASection — Editorial call-to-action with bronze glow,
 * display headline, and gold button that opens the contact panel.
 */
---

<section class="section-dark cta-section" data-nav-theme="dark">
  {/* Radial bronze glow behind content */}
  <div class="cta-section__glow" aria-hidden="true"></div>

  <div class="cta-section__content">
    {/* Headline — italic em in gold accent */}
    <h2 class="cta-section__headline animate-entrance">
      Have a brand that needs to<br />
      <em>stand out?</em>
    </h2>

    {/* Subtext */}
    <p class="cta-section__subtext">
      Let's talk about what strategic design can do for your shelf presence.
    </p>

    {/* CTA button — triggers contact panel via global function */}
    <button
      type="button"
      class="cta-section__button"
      onclick="openContactPanel()"
      aria-label="Open contact form"
    >
      Get in Touch
    </button>
  </div>
</section>

<style>
  /* ── Section wrapper ── */
  .cta-section {
    padding: 80px var(--space-5);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* ── Bronze radial glow ── */
  .cta-section__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(
      ellipse at 50% 60%,
      rgba(139, 107, 74, 0.08) 0%,
      transparent 50%
    );
  }

  /* ── Content wrapper ── */
  .cta-section__content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ── Headline ── */
  .cta-section__headline {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 400;
    color: var(--text-cream);
    line-height: 1.05;
    margin: 0 0 var(--space-3) 0;
  }

  /* Italic accent in gold */
  .cta-section__headline em {
    color: var(--accent-gold);
    font-style: italic;
  }

  /* ── Subtext ── */
  .cta-section__subtext {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: #7A756E;
    line-height: 1.6;
    margin: 0 0 var(--space-5) 0;
  }

  /* ── CTA button ── */
  .cta-section__button {
    display: inline-block;
    padding: 13px 32px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    color: var(--surface-charcoal);
    background: var(--accent-gold);
    border-radius: var(--radius-xl);
    border: none;
    cursor: pointer;
    transition: all 300ms var(--ease-spring);
    /* Ensure 44px min touch target */
    min-height: 44px;
  }

  @media (hover: hover) {
    .cta-section__button:hover {
      background: #E0B88A;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(212, 165, 116, 0.2);
    }
  }

  .cta-section__button:focus-visible {
    outline: 2px solid var(--accent-bronze);
    outline-offset: 2px;
  }

  .cta-section__button:active {
    transform: translateY(0);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .cta-section__button {
      transition: background 200ms ease, color 200ms ease;
    }

    .cta-section__button:hover {
      transform: none;
    }
  }
</style>
