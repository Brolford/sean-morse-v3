---
/**
 * HeroSection.astro
 * Asymmetric hero with left content zone and right stacked project cards.
 * Surface treatments: grain overlay + radial bronze wash.
 * Nav theme: light (tells nav.js to use light-mode pill).
 */
---

<section class="hero surface-grain" data-nav-theme="light" aria-label="Hero introduction">

  <!-- Radial bronze wash layer (sits behind content, above grain) -->
  <div class="hero-wash" aria-hidden="true"></div>

  <!-- Content zone — left 46% on desktop, full-width on mobile -->
  <div class="hero-content animate-entrance">
    <p class="hero-overline text-label">Sean Morse — Strategic Design</p>
    <h1 class="hero-headline text-display-xl">
      Strategic Design<br />
      Meets Visible<br />
      <em>Impact.</em>
    </h1>
    <p class="hero-description">
      Strategic packaging and brand identity for CPG brands.
      10+ years. $320M+ in influenced revenue.
    </p>
    <p class="hero-scroll-hint text-label" aria-hidden="true">
      <span class="scroll-arrow">&#8595;</span> Scroll to explore
    </p>
  </div>

  <!-- Image zone — right 58%, stacked project gradient cards -->
  <div class="hero-images" aria-hidden="true">
    <!-- Gradient mask prevents image/text overlap -->
    <div class="hero-images-mask"></div>

    <!-- 4 stacked cards — real images where available, gradient fallback -->
    <div class="hero-card hero-card--primary gradient-liquid-iv animate-entrance">
      <div class="hero-card-overlay"></div>
      <div class="hero-card-label">
        <span class="hero-card-category">Packaging</span>
        <span class="hero-card-name">Liquid I.V.</span>
      </div>
    </div>
    <div class="hero-card hero-card--secondary gradient-alecs animate-entrance">
      <img
        src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/d04ab052-bd59-4dc7-80b8-4aa3d25c4597/Alecs_CaseStudy_Layout_V3-14.jpg"
        alt=""
        class="hero-card__img"
        loading="eager"
        width="400"
        height="500"
      />
      <div class="hero-card-overlay"></div>
      <div class="hero-card-label">
        <span class="hero-card-category">Brand Identity</span>
        <span class="hero-card-name">Alec's Ice Cream</span>
      </div>
    </div>
    <div class="hero-card hero-card--tertiary gradient-v8 animate-entrance">
      <img
        src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/e6507e7f-df80-4286-bba1-2813fba5343c/V8_CaseStudy_2023_Logo_Ingredients.jpg"
        alt=""
        class="hero-card__img"
        loading="eager"
        width="400"
        height="500"
      />
      <div class="hero-card-overlay"></div>
      <div class="hero-card-label">
        <span class="hero-card-category">Packaging</span>
        <span class="hero-card-name">V8 + Campbell's</span>
      </div>
    </div>
    <div class="hero-card hero-card--ghost gradient-over-easy animate-entrance">
      <img
        src="https://images.squarespace-cdn.com/content/v1/57acaaf46a4963c5935b4584/4b2af325-0a75-45c5-ac4d-2c68495d8e57/OverEasy_CaseStudy_2023_Layout_V5-25.png"
        alt=""
        class="hero-card__img"
        loading="lazy"
        width="320"
        height="400"
      />
      <div class="hero-card-overlay"></div>
      <div class="hero-card-label">
        <span class="hero-card-category">Brand & Packaging</span>
        <span class="hero-card-name">Over Easy</span>
      </div>
    </div>
  </div>

</section>

<style>
  /* ====================================================================
     Hero — Full viewport, asymmetric layout
     ==================================================================== */

  .hero {
    position: relative;
    min-height: 100vh;
    background: var(--surface-canvas);
    overflow: hidden;
  }

  /* Bronze radial wash — positioned to warm the left content area */
  .hero-wash {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 30% 60%,
      rgba(139, 107, 74, 0.06) 0%,
      transparent 70%
    );
  }

  /* ====================================================================
     Content Zone — Left 46%
     ==================================================================== */

  .hero-content {
    position: absolute;
    bottom: 56px;
    left: 48px;
    max-width: 480px;
    z-index: 5;
  }

  /* Overline: "Sean Morse — Strategic Design" */
  .hero-overline {
    color: var(--accent-bronze);
    margin-bottom: var(--space-4);
  }

  /* Headline: "Strategic Design Meets Visible Impact." */
  .hero-headline {
    margin-bottom: var(--space-4);
  }

  .hero-headline em {
    font-style: italic;
    color: var(--accent-bronze);
  }

  /* Description paragraph */
  .hero-description {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: #6B6560;
    max-width: 400px;
    margin-bottom: var(--space-6);
  }

  /* Scroll hint with bouncing arrow */
  .hero-scroll-hint {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .scroll-arrow {
    display: inline-block;
    animation: bounce-arrow 2s var(--ease-smooth) infinite;
  }

  @keyframes bounce-arrow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  /* ====================================================================
     Image Zone — Right 58%, stacked gradient cards
     ==================================================================== */

  .hero-images {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 58%;
    z-index: 3;
  }

  /* Gradient mask on left edge — fades from canvas to transparent */
  .hero-images-mask {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 160px;
    z-index: 6;
    background: linear-gradient(
      to right,
      var(--surface-canvas) 0%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ====================================================================
     Individual Hero Cards
     ==================================================================== */

  .hero-card {
    position: absolute;
    border-radius: var(--radius-lg);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.15),
      0 6px 16px rgba(0, 0, 0, 0.08);
    will-change: transform;
  }

  /* Project image fills the card, sits above the gradient fallback */
  .hero-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
    z-index: 1;
  }

  /* Bottom gradient overlay for text legibility */
  .hero-card-overlay {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.35) 0%,
      transparent 40%
    );
    pointer-events: none;
  }

  /* Primary card (front) — Liquid I.V. colors */
  .hero-card--primary {
    width: 380px;
    height: 480px;
    top: 30px;
    right: 20px;
    transform: rotate(-3.5deg);
    z-index: 4;
  }

  /* Secondary card — Alec's colors */
  .hero-card--secondary {
    width: 320px;
    height: 400px;
    top: 10px;
    right: 340px;
    transform: rotate(3deg);
    z-index: 3;
  }

  /* Tertiary card — V8 colors */
  .hero-card--tertiary {
    width: 300px;
    height: 380px;
    bottom: 0;
    right: 170px;
    transform: rotate(-1deg);
    z-index: 5;
  }

  /* Ghost card — Over Easy colors, recessed but interactive */
  .hero-card--ghost {
    width: 240px;
    height: 300px;
    top: 80px;
    right: 560px;
    transform: rotate(1.5deg);
    z-index: 2;
    opacity: 0.5;
    filter: blur(1px);
  }

  /* ====================================================================
     Project Labels — positioned over the bottom gradient overlay
     Hidden by default, revealed on card hover (hover-capable devices)
     ==================================================================== */

  .hero-card-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-5) var(--space-5) var(--space-4);
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }

  .hero-card-category {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .hero-card-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
  }

  /* ====================================================================
     Card Hover — focus behavior with sibling dimming
     Only on devices that support hover (no touch)
     ==================================================================== */

  @media (hover: hover) {
    .hero-card {
      transition:
        opacity 300ms var(--ease-spring),
        transform 500ms var(--ease-spring),
        box-shadow 500ms var(--ease-spring),
        filter 300ms var(--ease-spring),
        z-index 0ms;
    }

    .hero-card-label {
      transition:
        opacity 300ms ease,
        transform 300ms ease;
    }

    /* When ANY card in the group is hovered, dim all cards */
    .hero-images:hover .hero-card {
      opacity: 0.85;
    }

    /* Ghost starts dimmer, so dim it further when siblings are hovered */
    .hero-images:hover .hero-card--ghost {
      opacity: 0.35;
    }

    /* The hovered card snaps to full opacity, straightens, scales, deepens shadow */
    .hero-images:hover .hero-card:hover {
      opacity: 1;
      z-index: 10;
      transform: rotate(0deg) scale(1.05);
      filter: blur(0);
      box-shadow:
        0 32px 80px rgba(0, 0, 0, 0.22),
        0 10px 24px rgba(0, 0, 0, 0.12);
    }

    /* Reveal label on any hovered card */
    .hero-card:hover .hero-card-label {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ====================================================================
     Mobile — max-width 768px
     ==================================================================== */

  @media (max-width: 768px) {
    .hero {
      min-height: 80vh;
    }

    /* Content zone becomes flow layout, not absolute */
    .hero-content {
      position: relative;
      bottom: auto;
      left: auto;
      width: 100%;
      max-width: none;
      padding: 120px 24px 48px;
    }

    .hero-description {
      max-width: none;
    }

    /* Image zone: single card as background decoration */
    .hero-images {
      position: absolute;
      top: auto;
      bottom: 0;
      right: 0;
      width: 100%;
      height: 40%;
      opacity: 0.12;
      pointer-events: none;
    }

    .hero-images-mask {
      display: none;
    }

    /* Hide labels on mobile — cards are background-only */
    .hero-card-label {
      display: none;
    }

    /* Hide all but primary card on mobile */
    .hero-card--secondary,
    .hero-card--tertiary,
    .hero-card--ghost {
      display: none;
    }

    /* Primary card centers as subtle background element */
    .hero-card--primary {
      width: 280px;
      height: 360px;
      top: auto;
      bottom: 0;
      right: -40px;
      transform: rotate(-2deg);
    }
  }

  /* ====================================================================
     Reduced Motion — disable bounce arrow
     ==================================================================== */

  @media (prefers-reduced-motion: reduce) {
    .scroll-arrow {
      animation: none;
    }
  }
</style>
