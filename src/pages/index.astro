---
/**
 * index.astro — Homepage for Sean Morse portfolio v3.
 * Assembles all section components in presentation order.
 */
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import AccomplishmentGallery from '../components/AccomplishmentGallery.astro';
import FeaturedScroll from '../components/FeaturedScroll.astro';
import BentoGrid from '../components/BentoGrid.astro';
import ImpactMetrics from '../components/ImpactMetrics.astro';
import BrandsGrid from '../components/BrandsGrid.astro';
import CTASection from '../components/CTASection.astro';
import ContactPanel from '../components/ContactPanel.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Sean Morse — Strategic Design"
  description="Strategic packaging and brand identity for CPG brands. 10+ years. $320M+ in influenced revenue."
>
  <Nav />

  <main id="main">
    <HeroSection />
    <AccomplishmentGallery />
    <FeaturedScroll />
    <BentoGrid />
    <ImpactMetrics />
    <BrandsGrid />
    <CTASection />
  </main>

  <!-- Fixed overlay panel — outside main content flow -->
  <ContactPanel />

  <Footer />
</Base>
